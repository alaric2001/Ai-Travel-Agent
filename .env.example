# =============================================================
# AI Travel Agent — Environment Variables
# Salin file ini menjadi .env dan isi nilai yang sesuai
# JANGAN commit file .env ke version control
# =============================================================

# ── Database PostgreSQL ───────────────────────────────────────
DB_NAME=travel_agent_db
DB_USER=travel_admin
DB_PASSWORD=ganti_password_ini_sekarang
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=ganti_redis_password_ini
REDIS_PORT=6379

# ── AI / LLM API Keys ─────────────────────────────────────────
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...your_gemini_api_key

# ── SerpApi (Real-time Flights & Hotels) ─────────────────────
# Dapatkan di: https://serpapi.com (free 100 req/bulan)
# Digunakan oleh Booking Agent untuk cari tiket & hotel real-time
SERPAPI_KEY=your_serpapi_key_here

# ── Google Maps API ───────────────────────────────────────────
# Aktifkan: Maps JavaScript API, Directions API, Distance Matrix API
# Dapatkan di: https://console.cloud.google.com/apis
GOOGLE_MAPS_API_KEY=AIza...your_maps_api_key

# ── Authentication ────────────────────────────────────────────
# Generate dengan: openssl rand -hex 32
JWT_SECRET=generate_random_256bit_string_here
JWT_EXPIRES_IN=8h

# ── App Ports ─────────────────────────────────────────────────
API_PORT=3001
WEB_PORT=3000

# ── File Upload ───────────────────────────────────────────────
# Ukuran max upload struk foto (dalam bytes). Default: 5MB
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=./uploads

# ── Dify.ai (Opsional — untuk orkestrasi workflow) ────────────
# Jika menggunakan Dify self-hosted:
DIFY_API_URL=http://localhost:8080
DIFY_API_KEY=your_dify_api_key
